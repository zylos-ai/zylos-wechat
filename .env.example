# Component
ZYLOS_WECHAT_ENABLED=true
ZYLOS_WECHAT_LOG_LEVEL=info
ZYLOS_WECHAT_DATA_DIR=./data

# WeChat account auth / runtime
WECHAT_API_BASE=https://ilinkai.weixin.qq.com
WECHAT_ACCESS_TOKEN=
WECHAT_UIN=
WECHAT_DEVICE_ID=
WECHAT_POLL_TIMEOUT_MS=35000
WECHAT_POLL_INTERVAL_MS=300

# C4 bridge receive script path
C4_RECEIVE_SCRIPT=~/.claude/skills/comm-bridge/scripts/c4-receive.js

# Optional: allow only specific DM users (comma separated ids)
ZYLOS_WECHAT_DM_ALLOWLIST=
